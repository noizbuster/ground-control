{
  "name": "gctrl",
  "version": "0.1.3",
  "description": "Real-time OpenCode session monitor CLI",
  "type": "module",
  "scripts": {
    "start": "node ./bin/gctrl.js",
    "dev": "npx tsc --project tsconfig.build.json --watch",
    "typecheck": "npx tsc --noEmit",
    "build": "npx tsc --project tsconfig.build.json && node scripts/fix-dist-imports.mjs",
    "lint": "npx @biomejs/biome check src",
    "check": "npm run lint && npm run typecheck",
    "prepack": "npm run build"
  },
  "bin": {
    "gctrl": "./bin/gctrl.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "keywords": [
    "opencode",
    "tui",
    "node",
    "opentui",
    "sqlite",
    "monitor"
  ],
  "author": "NoizBuster <noizbuster@noizbuster.com>",
  "license": "MIT",
  "repository": "https://github.com/noizbuster/ground-control",
  "dependencies": {
    "@opentui/core": "^0.1.88"
  },
  "devDependencies": {
    "@types/node": "^22.10.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}

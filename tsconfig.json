{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
	"types": [
	  "node"
	],
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
	"include": [
	  "src/**/*.ts",
	  "src/**/*.tsx",
	  "src/**/*.d.ts"
	],
  "exclude": [
    "node_modules"
  ]
}
